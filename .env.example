# Backend Selection: 'supabase' or 'leancloud'
VITE_BACKEND=supabase

# ===========================================
# Supabase Configuration (default)
# ===========================================
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ===========================================
# LeanCloud Configuration (China-optimized)
# Get keys from: https://console.leancloud.cn/
# ===========================================
VITE_LEANCLOUD_APP_ID=your_leancloud_app_id
VITE_LEANCLOUD_APP_KEY=your_leancloud_app_key
VITE_LEANCLOUD_SERVER_URL=https://your-app-id.leancloud.cn

# ===========================================
# Amap API Key (https://lbs.amap.com/)
# ===========================================
VITE_AMAP_KEY=your_amap_key
VITE_AMAP_SECURITY_KEY=your_amap_security_key
VITE_AMAP_JS_KEY=your_amap_js_key
VITE_AMAP_JS_SECURITY_KEY=your_amap_js_security_key

# ===========================================
# Error Monitoring (optional - for production)
# ===========================================
# Sentry - https://sentry.io/
VITE_SENTRY_DSN=your_sentry_dsn
# Fundebug (China) - https://www.fundebug.com/
VITE_FUNDEBUG_APIKEY=your_fundebug_apikey
